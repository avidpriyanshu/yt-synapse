filters:
  and:
    - file.tags.contains("youtube/video")
views:
  - type: table
    name: All Videos
    order:
      - file.name
      - channel
      - date
      - topics
      - file.ctime
    sort:
      - property: file.ctime
        direction: DESC
      - property: date
        direction: DESC
      - property: channel
        direction: ASC
