{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "command": "/Users/avid/.nvm/versions/node/v22.15.1/bin/caliber learn observe"
      }
    ],
    "postToolUseFailure": [
      {
        "command": "/Users/avid/.nvm/versions/node/v22.15.1/bin/caliber learn observe --failure"
      }
    ],
    "userPromptSubmit": [
      {
        "command": "/Users/avid/.nvm/versions/node/v22.15.1/bin/caliber learn observe --prompt"
      }
    ],
    "sessionEnd": [
      {
        "command": "/Users/avid/.nvm/versions/node/v22.15.1/bin/caliber learn finalize --auto"
      }
    ]
  }
}