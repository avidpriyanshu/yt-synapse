# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Obsidian workspace (user-specific, shouldn't be committed)
obsidian-vault/.obsidian/workspace*
obsidian-vault/.obsidian/plugins/

# Local env
.env
.env.local

# Optional npm cache directory
.npm

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Generated content (keep only structure)
# Usually you'd want to commit the structure but not user data
# Uncomment if you want to exclude generated videos/topics:
# obsidian-vault/videos/
# obsidian-vault/topics/
# obsidian-vault/channels/
# obsidian-vault/clippings/

# Planning trash (archived/deleted artifacts)
.planning/.trash/
